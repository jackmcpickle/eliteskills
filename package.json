{
  "name": "eliteskills",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "test": "pnpm run fmt:check && pnpm run lint && pnpm vitest",
    "test:coverage": "pnpm run fmt:check && pnpm run lint && vitest run --coverage.enabled",
    "lint": "oxlint --type-aware --type-check --fix src/",
    "fmt:check": "oxfmt \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css,astro}\" --check",
    "fmt": "oxfmt \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css,astro}\" --write",
    "vitest": "vitest run --coverage.enabled",
    "test:e2e": "playwright test --grep-invert @llm",
    "test:llm": "playwright test --grep @llm",
    "test:skills": "playwright test --grep @llm tests/e2e/skill-quality.spec.ts",
    "test:live-agent": "playwright test --grep @live",
    "build:manifest": "pnpm exec vite-node scripts/build-skills-manifest.ts",
    "test:flow": "pnpm vitest && pnpm test:e2e",
    "test:ci": "pnpm vitest && pnpm test:e2e && pnpm test:llm && pnpm test:live-agent",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "astro dev",
    "build:skills": "pnpm exec vite-node scripts/build-skills-zip.ts",
    "stripe:sync": "pnpm exec vite-node scripts/sync-stripe-products.ts",
    "stripe:cleanup": "pnpm exec vite-node scripts/cleanup-stripe-duplicates.ts",
    "build": "pnpm build:manifest && pnpm build:skills && astro build",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/sitemap": "^3.7.0",
    "@lucide/astro": "^0.575.0",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^5.17.1",
    "drizzle-orm": "^0.45.1",
    "fflate": "^0.8.2",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@cloudflare/workers-types": "^4.20260228.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "prettier-plugin-astro": "^0.14.1",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
