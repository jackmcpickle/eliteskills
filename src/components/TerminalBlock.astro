---
interface Props {
	label: string;
	class?: string;
}

const { label, class: className = '' } = Astro.props;
---

<div class:list={['scan-line relative rounded-2xl border border-border bg-surface overflow-hidden', className]}>
	<div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface-hover">
		<div class="size-3 rounded-full bg-red-400/60"></div>
		<div class="size-3 rounded-full bg-neon-amber/60"></div>
		<div class="size-3 rounded-full bg-neon-green/60"></div>
		<span class="ml-2 font-mono text-[11px] text-ghost">{label}</span>
	</div>
	<slot />
</div>
