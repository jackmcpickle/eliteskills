---
import { Bot, Code, ShieldCheck } from '@lucide/astro';

const features = [
	{
		icon: 'Code',
		title: 'API Access',
		description:
			'Integrate Elite Skills directly into your AI agent pipelines. Fetch, configure, and deploy skills programmatically via our REST API.',
	},
	{
		icon: 'ShieldCheck',
		title: 'Human-in-the-Loop Purchases',
		description:
			'Bots can browse and select skills, then hand off to a human for secure purchase approval. No unauthorized spending.',
	},
	{
		icon: 'Bot',
		title: 'Agent-Ready Skills',
		description:
			'Skills are structured for machine consumption. Your AI agents parse, apply, and chain them without manual setup.',
	},
];

const iconMap = { Code, ShieldCheck, Bot };

const agentPrompt = `Search eliteskills.ai for agent skills that can help with my current task and install them.`;

const codeSnippet = `// Fetch available skills
const res = await fetch('https://api.eliteskills.ai/v1/skills', {
  headers: { Authorization: \`Bearer \${API_KEY}\` },
});
const skills = await res.json();

// Request human approval for purchase
await requestApproval({
  skill: skills[0],
  callback: 'https://your-app.com/approve',
});`;
---

<section class="relative py-32 px-6">
	<!-- Ambient glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[600px] rounded-full bg-neon-violet/5 blur-[140px] pointer-events-none"></div>

	<div class="relative max-w-5xl mx-auto">
		<!-- Section header -->
		<div class="text-center mb-20">
			<p class="reveal font-mono text-xs text-neon-cyan tracking-[0.3em] uppercase mb-4">AI Agent Integration</p>
			<h2 class="reveal reveal-delay-1 font-display text-4xl sm:text-5xl md:text-6xl font-800 text-white tracking-tight">
				Built for Bots, Approved&nbsp;by&nbsp;Humans
			</h2>
			<p class="reveal reveal-delay-2 mt-4 max-w-xl mx-auto text-mist">
				Let your AI agents discover, evaluate, and use Elite Skills via API&mdash;with human approval for purchases.
			</p>
		</div>

		<!-- Two-column layout: features + code -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
			<!-- Feature cards -->
			<div class="space-y-6">
				{features.map((feature, i) => {
					const Icon = iconMap[feature.icon as keyof typeof iconMap];
					return (
						<div class={`reveal reveal-delay-${i + 1} scroll-sheen electron-border neon-hover group relative flex gap-5 rounded-2xl border border-border p-6 hover:border-neon-cyan-dim`} style={`--scroll-delay: ${i * 60}ms`}>
							<div class={`flex shrink-0 items-center justify-center size-12 rounded-full bg-neon-cyan-glow border border-neon-cyan-dim text-neon-cyan glow-breathe glow-breathe-delay-${i + 1} transition-shadow group-hover:shadow-[0_0_30px_var(--color-neon-cyan-glow)]`}>
								<Icon class="size-6" aria-hidden="true" />
							</div>
							<div>
								<h3 class="font-display text-lg font-700 text-white mb-1">{feature.title}</h3>
								<p class="text-sm text-mist leading-relaxed">{feature.description}</p>
							</div>
							<div class="absolute bottom-0 inset-x-6 h-px bg-gradient-to-r from-transparent via-neon-cyan-dim to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
						</div>
					);
				})}
			</div>

			<!-- Code preview -->
			<div class="reveal reveal-delay-2 scan-line scroll-border-trace relative rounded-2xl border border-border bg-surface overflow-hidden">
				<!-- Terminal header -->
				<div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface-hover">
					<div class="size-3 rounded-full bg-red-400/60"></div>
					<div class="size-3 rounded-full bg-neon-amber/60"></div>
					<div class="size-3 rounded-full bg-neon-green/60"></div>
					<span class="ml-2 font-mono text-[11px] text-ghost">agent.ts</span>
				</div>
				<!-- Code content -->
				<pre class="p-5 overflow-x-auto font-mono text-xs leading-relaxed text-cloud"><code set:text={codeSnippet} /></pre>
			</div>
		</div>

		<!-- Agent prompt panel -->
		<div class="reveal reveal-delay-4 mt-12 mx-auto max-w-2xl electron-border scroll-sheen neon-hover rounded-2xl border border-border bg-surface p-6">
			<p class="font-mono text-xs text-ghost tracking-wider mb-3">Tell your agent:</p>
			<div class="flex items-center gap-3 rounded-lg border border-slate-mid bg-abyss px-4 py-3">
				<code class="flex-1 font-mono text-sm text-neon-cyan select-all">{agentPrompt}</code>
				<button
					type="button"
					class="copy-btn shrink-0 rounded border border-slate-mid px-2.5 py-1.5 font-mono text-xs text-ghost hover:border-neon-cyan-dim hover:text-neon-cyan transition-all"
					data-copy={agentPrompt}
				>
					Copy
				</button>
			</div>
		</div>
	</div>
</section>

<script>
	document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const text = btn.dataset.copy;
			if (!text) return;
			try {
				await navigator.clipboard.writeText(text);
				const original = btn.textContent;
				btn.textContent = 'Copied!';
				setTimeout(() => { btn.textContent = original; }, 1500);
			} catch {
				const code = btn.previousElementSibling;
				if (code) {
					const range = document.createRange();
					range.selectNodeContents(code);
					const sel = window.getSelection();
					sel?.removeAllRanges();
					sel?.addRange(range);
				}
			}
		});
	});
</script>
