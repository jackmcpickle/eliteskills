---
import { FileCode, Blocks } from '@lucide/astro';

const genericSkills = [
	'"You are a senior frontend developer. Never make mistakes."',
	'"Always write clean, maintainable code with best practices."',
	'"Use TypeScript strictly and handle all edge cases."',
	'"Follow SOLID principles. Write comprehensive tests."',
];

const eliteSkills = [
	'Compound component patterns with slot APIs and composition boundaries',
	'Query key factories, stale-time hierarchies, and cache invalidation strategies',
	'Form state machines: idle → validating → submitting → success | error → retry',
	'Optimistic mutations with rollback, error boundaries, and retry policies',
];
---

<section class="relative py-16 sm:py-24 lg:py-32 px-6">
	<!-- Ambient glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[600px] rounded-full bg-neon-violet/5 blur-[140px] pointer-events-none"></div>

	<div class="relative max-w-5xl mx-auto">
		<!-- Section header -->
		<div class="text-center mb-10 sm:mb-16 lg:mb-20">
			<p class="reveal font-mono text-xs text-neon-cyan tracking-[0.3em] uppercase mb-4">The Difference</p>
			<h2 class="reveal reveal-delay-1 font-display text-4xl sm:text-5xl md:text-6xl font-800 text-white tracking-tight">
				Patterns, Not Pep Talks
			</h2>
			<p class="reveal reveal-delay-2 mt-4 max-w-xl mx-auto text-mist">
				Open-source skills assign a persona. Ours encode the architecture decisions that hold up at scale.
			</p>
		</div>

		<!-- Comparison cards -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<!-- Generic open source skills -->
			<div class="reveal reveal-delay-1 scroll-border-trace group relative rounded-2xl border border-red-500/20 bg-surface p-8 sm:p-10">
				<div class="flex items-center gap-3 mb-6">
					<div class="flex items-center justify-center size-10 rounded-full bg-red-500/10 border border-red-500/20 text-red-400">
						<FileCode class="size-5" aria-hidden="true" />
					</div>
					<h3 class="font-display text-lg font-700 text-ghost">Generic Open Source Skills</h3>
				</div>

				<ul class="space-y-4">
					{genericSkills.map((skill) => (
						<li class="font-mono text-xs sm:text-sm text-ghost/70 leading-relaxed pl-4 border-l-2 border-red-500/20 break-words">
							{skill}
						</li>
					))}
				</ul>
			</div>

			<!-- Elite Skills -->
			<div class="reveal reveal-delay-2 scan-line scroll-border-trace group relative rounded-2xl border-2 border-neon-cyan bg-surface p-8 sm:p-10 shadow-[0_0_60px_var(--color-neon-cyan-glow)]" style="--scroll-delay: 100ms">
				<div class="flex items-center gap-3 mb-6">
					<div class="flex items-center justify-center size-10 rounded-full bg-neon-cyan-glow border border-neon-cyan-dim text-neon-cyan">
						<Blocks class="size-5" aria-hidden="true" />
					</div>
					<h3 class="font-display text-lg font-700 text-white">Elite Skills</h3>
				</div>

				<ul class="space-y-4">
					{eliteSkills.map((skill) => (
						<li class="font-mono text-xs sm:text-sm text-cloud leading-relaxed pl-4 border-l-2 border-neon-cyan break-words">
							{skill}
						</li>
					))}
				</ul>
			</div>
		</div>

		<!-- Bottom text -->
		<p class="reveal reveal-delay-3 text-center mt-12 font-mono text-xs text-ghost tracking-wider">
			Proven architecture from production-scale apps. Not roleplay.
		</p>
	</div>
</section>
