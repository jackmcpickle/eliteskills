<footer class="relative py-16 sm:py-24 px-6">
	<!-- Top border -->
	<div class="absolute top-0 inset-x-0 h-px border-flow"></div>

	<div class="max-w-3xl mx-auto text-center">
		<h2 class="reveal font-display text-3xl sm:text-4xl font-800 text-white tracking-tight mb-4">
			Stop Settling for Mid Output
		</h2>
		<p class="reveal reveal-delay-1 text-mist mb-8 max-w-lg mx-auto">
			Your AI is only as good as its instructions. Give it 20 years of hard-won engineering knowledge.
		</p>
		<div class="shimmer reveal reveal-delay-2 group inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-neon-cyan text-void font-mono font-700 text-sm tracking-wide transition-all">
			<span class="select-all">npx skills add mcpick/eliteskills</span>
		</div>

		<!-- About callout -->
		<div class="reveal reveal-delay-3 mt-12 sm:mt-16 rounded-lg border border-border bg-surface/50 px-6 py-5 max-w-lg mx-auto">
			<p class="text-sm text-cloud leading-relaxed mb-3">
				Built by <span class="text-white font-600">Jack McNicol</span> &mdash; 20+ years shipping production software, from legacy transformations to AI agents.
			</p>
			<a href="/about" class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-wide text-neon-cyan hover:underline">
				<span>Meet the builder</span>
				<span>&rarr;</span>
			</a>
		</div>

		<div class="mt-12 sm:mt-20 pt-8 border-t border-border">
			<div class="mb-4 flex items-center justify-center gap-6">
				<a href="/" class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan">Home</a>
				<a href="/skills" class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan">Skills</a>
				<a href="/about" class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan">About</a>
				<a href="/contact" class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan">Contact</a>
				<a href="/llm.txt" class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan">LLM</a>
			</div>
			<p class="font-mono text-xs text-ghost tracking-wider">
				&copy; {new Date().getFullYear()} Elite Skills &middot; Built by <span class="text-mist">Jack McNicol</span>
			</p>
		</div>
	</div>
</footer>
