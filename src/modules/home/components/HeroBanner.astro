---

---

<section id="main-content" class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden">
	<!-- Radial glow behind hero -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[800px] rounded-full bg-neon-cyan/5 blur-[160px] pointer-events-none"></div>
	<div class="absolute top-1/3 right-1/4 size-[400px] rounded-full bg-neon-violet/5 blur-[120px] pointer-events-none"></div>

	<div class="relative z-10 max-w-4xl mx-auto text-center">
		<!-- Badge -->
		<div class="reveal inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-neon-cyan-dim bg-neon-cyan-glow font-mono text-xs text-neon-cyan tracking-widest uppercase">
			<span class="size-1.5 rounded-full bg-neon-amber glow-pulse"></span>
			20 Years of Engineering Distilled
		</div>

		<!-- Headline -->
		<h1 class="reveal reveal-delay-1 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-900 tracking-tight leading-[0.95] mb-6">
			<span class="text-white">Elite AI Skills</span>
			<br />
			<span class="text-neon">for Builders</span>
		</h1>

		<!-- Subhead -->
		<p class="reveal reveal-delay-2 max-w-2xl mx-auto text-lg sm:text-xl text-mist leading-relaxed mb-10">
			Supercharge your AI coding tools with battle&#8209;tested skills crafted from two decades of shipping production software.
			<span class="text-ghost">Built for vibe coders, founders, and builders who refuse to settle for generic output.</span>
		</p>

		<!-- CTA row -->
		<div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4">
			<a href="#pricing" class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-neon-cyan text-void font-mono font-700 text-sm tracking-wide uppercase overflow-hidden transition-all hover:shadow-[0_0_40px_var(--color-neon-cyan-dim)]">
				<span class="relative z-10">Get the Skills</span>
				<span class="relative z-10 transition-transform group-hover:translate-x-1">&rarr;</span>
				<div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
			</a>
			<a href="#skills" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg border border-slate-mid text-mist font-mono text-sm tracking-wide uppercase hover:border-neon-cyan-dim hover:text-neon-cyan transition-colors">
				See What's Inside
			</a>
		</div>

		<!-- Author credit -->
		<p class="reveal reveal-delay-4 mt-16 font-mono text-xs text-ghost tracking-wider">
			Crafted by <span class="text-mist">Jack McNicol</span> &mdash; 20 years shipping code
		</p>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-ghost">
		<span class="font-mono text-[10px] tracking-[0.3em] uppercase">Scroll</span>
		<div class="w-px h-8 bg-gradient-to-b from-neon-amber to-transparent"></div>
	</div>
</section>
