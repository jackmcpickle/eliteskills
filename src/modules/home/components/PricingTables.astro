---
import { Check } from '@lucide/astro';
import { formatMoney } from '@/utils/format-money';

interface ProductDisplay {
	id: number;
	code: string;
	name: string;
	price: number;
	currency: string;
	lifetime: number;
	skillSlug: string | null;
}

interface Props {
	bundleProducts: ProductDisplay[];
	skillProducts: ProductDisplay[];
	locale: string;
}

const { bundleProducts, skillProducts, locale } = Astro.props;

const singleSkill = skillProducts[0];
const allSkills = bundleProducts.find((p) => p.code === 'bundle-once');
const lifetimeAccess = bundleProducts.find((p) => p.code === 'bundle-lifetime');
const teams = bundleProducts.find((p) => p.code === 'bundle-teams');

const middleTiers = [allSkills, lifetimeAccess].filter(Boolean) as ProductDisplay[];
---

<section id="pricing" class="relative py-16 sm:py-24 lg:py-32 px-6">
	<div class="absolute top-0 left-1/2 -translate-x-1/2 size-[500px] rounded-full bg-neon-cyan/5 blur-[140px] pointer-events-none"></div>

	<div class="relative max-w-4xl mx-auto">
		<div class="text-center mb-10 sm:mb-16 lg:mb-20">
			<p class="reveal font-mono text-xs text-neon-cyan tracking-[0.3em] uppercase mb-4">Pricing</p>
			<h2 class="reveal reveal-delay-1 font-display text-4xl sm:text-5xl md:text-6xl font-800 text-white tracking-tight">
				Invest in Your Edge
			</h2>
			<p class="reveal reveal-delay-2 mt-4 max-w-lg mx-auto text-mist">
				Plans for every builder. No subscriptions. No hidden fees. Pay once and build.
			</p>
			<p class="reveal reveal-delay-2 mt-2 font-mono text-xs text-ghost">
				Prices adjusted for your region
			</p>
		</div>

		<div class="flex flex-col gap-6">
			{singleSkill && (
				<a href={`/checkout/${singleSkill.id}`} class="reveal reveal-delay-1 group relative rounded-xl border border-border bg-surface hover:border-neon-cyan-dim p-5 sm:p-6 transition-all">
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
						<div class="flex-1 min-w-0">
							<h3 class="font-display text-lg font-700 text-white">Single Skill</h3>
							<p class="text-sm text-ghost mt-1">Pick one elite skill and start building immediately.</p>
						</div>

						<div class="flex items-center gap-6 sm:gap-8">
							<ul class="hidden md:flex items-center gap-4">
								<li class="flex items-center gap-1.5 text-xs text-cloud">
									<Check class="size-3.5 text-neon-green" aria-hidden="true" />1 elite skill
								</li>
								<li class="flex items-center gap-1.5 text-xs text-cloud">
									<Check class="size-3.5 text-neon-green" aria-hidden="true" />Instant download
								</li>
								<li class="flex items-center gap-1.5 text-xs text-cloud">
									<Check class="size-3.5 text-neon-green" aria-hidden="true" />Forever access
								</li>
							</ul>

							<div class="flex items-center gap-3">
								<div class="flex items-baseline gap-0.5">
									<span class="font-display text-3xl font-900 tracking-tight text-white">{formatMoney(singleSkill.price, singleSkill.currency, locale)}</span>
									<span class="font-mono text-xs text-ghost ml-0.5">/ skill</span>
								</div>
								<span class="shrink-0 px-4 py-2 rounded-lg border border-slate-mid text-mist font-mono text-xs font-600 tracking-wide uppercase group-hover:border-neon-cyan-dim group-hover:text-neon-cyan transition-all">
									Buy
								</span>
							</div>
						</div>
					</div>
				</a>
			)}

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
				{middleTiers.map((tier, i) => {
					const isLifetime = tier.code === 'bundle-lifetime';
					const features = isLifetime
						? ['All 6 elite skills included', 'Instant download', 'Use with any AI coding tool', 'Community Discord access', 'All future updates included', 'New skills as they launch', 'Priority support']
						: ['All 6 elite skills included', 'Instant download', 'Use with any AI coding tool', 'Community Discord access', 'Current version snapshot'];

					return (
						<div class={`reveal reveal-delay-${i + 2} relative rounded-2xl p-8 sm:p-10 transition-all ${
							isLifetime
								? 'border-2 border-neon-cyan bg-surface shadow-[0_0_60px_var(--color-neon-cyan-glow)]'
								: 'border border-border bg-surface hover:border-neon-cyan-dim'
						}`}>
						{isLifetime && (
							<div class="shimmer absolute -top-3.5 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-neon-cyan text-void font-mono text-xs font-700 tracking-wider uppercase">
								Best Value
							</div>
						)}

						<h3 class="font-display text-xl font-700 text-white mb-2">{tier.name}</h3>
						<p class="text-sm text-ghost mb-8">
							{isLifetime ? 'Every update, every new skill, forever.' : 'Get the full skill pack as it exists today.'}
						</p>

						<div class="flex items-baseline gap-1 mb-8">
							<span class={`font-display text-5xl sm:text-6xl font-900 tracking-tight ${isLifetime ? 'text-neon-cyan' : 'text-white'}`}>
								{formatMoney(tier.price, tier.currency, locale)}
							</span>
							<span class="font-mono text-sm text-ghost ml-1">/ {isLifetime ? 'lifetime' : 'once'}</span>
						</div>

						<ul class="space-y-3 mb-10">
							{features.map((feature) => (
								<li class="flex items-start gap-3 text-sm">
									<Check class={`size-4 mt-0.5 ${isLifetime ? 'text-neon-cyan' : 'text-neon-green'}`} aria-hidden="true" />
									<span class="text-cloud">{feature}</span>
								</li>
							))}
						</ul>

						<a href={`/checkout/${tier.id}`} class={`block w-full text-center py-4 rounded-lg font-mono text-sm font-600 tracking-wide uppercase transition-all ${
							isLifetime
								? 'bg-neon-cyan text-void hover:shadow-[0_0_40px_var(--color-neon-cyan-dim)]'
								: 'border border-slate-mid text-mist hover:border-neon-cyan-dim hover:text-neon-cyan'
						}`}>
							{isLifetime ? 'Get Lifetime Access' : 'Buy Now'}
						</a>
						</div>
					);
				})}
			</div>

			{teams && (
				<a href={`/checkout/${teams.id}`} class="reveal reveal-delay-4 group relative rounded-xl border border-border/60 bg-surface/50 hover:border-neon-cyan-dim p-5 sm:p-6 transition-all">
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
						<div class="flex-1 min-w-0">
							<div class="flex items-center gap-2">
								<h3 class="font-display text-lg font-700 text-mist">{teams.name}</h3>
								<span class="px-2 py-0.5 rounded-full bg-white/5 font-mono text-[10px] text-ghost uppercase tracking-wider">Unlimited seats</span>
							</div>
							<p class="text-sm text-ghost mt-1">Unlimited seats for your entire team. Every skill, every update, forever.</p>
						</div>

						<div class="flex items-center gap-3">
							<div class="flex items-baseline gap-0.5">
								<span class="font-display text-3xl font-900 tracking-tight text-mist">{formatMoney(teams.price, teams.currency, locale)}</span>
								<span class="font-mono text-xs text-ghost ml-0.5">/ once</span>
							</div>
							<span class="shrink-0 px-4 py-2 rounded-lg border border-slate-mid/60 text-ghost font-mono text-xs font-600 tracking-wide uppercase group-hover:border-neon-cyan-dim group-hover:text-neon-cyan transition-all">
								Get Started
							</span>
						</div>
					</div>
				</a>
			)}
		</div>

		<p class="reveal reveal-delay-5 text-center mt-12 font-mono text-xs text-ghost tracking-wider">
			Secure checkout &middot; Instant delivery &middot; 30-day money-back guarantee
		</p>
	</div>
</section>
