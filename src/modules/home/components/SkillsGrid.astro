---
import { getCollection } from 'astro:content';
import { Database, Layers, Palette, Rocket, ShieldCheck, Sparkles } from '@lucide/astro';
import { formatMoney } from '@/utils/format-money';

interface ProductDisplay {
	id: number;
	code: string;
	name: string;
	price: number;
	currency: string;
	lifetime: number;
	skillSlug: string | null;
}

interface Props {
	skillProducts: ProductDisplay[];
	locale: string;
}

const { skillProducts, locale } = Astro.props;

const skills = (await getCollection('skills')).sort((a, b) => a.data.order - b.data.order);

const iconMap = { Database, Layers, Palette, Rocket, ShieldCheck, Sparkles };

// Map skill slug -> product id for buy links
const slugToProduct = new Map(skillProducts.map((p) => [p.skillSlug, p]));
---

<section id="skills" class="relative py-16 sm:py-24 lg:py-32 px-6">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-10 sm:mb-16 lg:mb-20">
			<p class="reveal font-mono text-xs text-neon-cyan tracking-[0.3em] uppercase mb-4">The Arsenal</p>
			<h2 class="reveal reveal-delay-1 font-display text-4xl sm:text-5xl md:text-6xl font-800 text-white tracking-tight">
				Skills That Ship
			</h2>
			<p class="reveal reveal-delay-2 mt-4 max-w-xl mx-auto text-mist">
				Each skill is a precision-engineered instruction set that transforms how your AI writes code.
			</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			{skills.map((skill, i) => {
				const Icon = iconMap[skill.data.icon as keyof typeof iconMap] ?? Sparkles;
				const slug = skill.id.replace(/\.md$/, '');
				const product = slugToProduct.get(slug);
				const { released } = skill.data;
				const href = `/skills/${slug}`;

				return (
				<a href={href} class:list={[
					`reveal reveal-delay-${i + 1} card-glow electron-border group rounded-xl bg-surface p-8 transition-all`,
					released ? 'hover:bg-surface-hover' : 'opacity-70',
				]}>
					<div class={`flex items-center justify-center size-12 mb-6 rounded-lg bg-neon-cyan-glow border border-neon-cyan-dim text-neon-cyan glow-breathe glow-breathe-delay-${(i % 3) + 1}`}>
						<Icon class="size-5" aria-hidden="true" />
					</div>

					<h3 class="font-display text-xl font-700 text-white mb-3 group-hover:text-neon-cyan transition-colors">
						{skill.data.title}
					</h3>

					<p class="text-sm text-mist leading-relaxed mb-4">
						{skill.data.description}
					</p>

					{released && product ? (
						<div>
							<span class="inline-flex items-center gap-1.5 font-mono text-xs text-neon-cyan">
								<span>{formatMoney(product.price, product.currency, locale)}</span>
								<span class="text-ghost">&middot;</span>
								<span>Buy skill</span>
							</span>
							<span class="block font-mono text-[10px] text-ghost mt-1">Prices adjusted for your region</span>
						</div>
					) : (
						<span class="inline-flex items-center px-2 py-0.5 rounded-full border border-neon-amber/40 bg-neon-amber/10 font-mono text-[10px] text-neon-amber tracking-wider uppercase">
							Coming Soon
						</span>
					)}

					<div class="absolute top-0 right-0 size-16 opacity-0 group-hover:opacity-100 transition-opacity">
						<div class="absolute top-3 right-3 size-1 rounded-full bg-neon-amber"></div>
					</div>
				</a>
				);
			})}
		</div>
	</div>
</section>
