---
import TerminalBlock from '@/components/TerminalBlock.astro';
import { skillSlashCommand } from "@/utils/skill-command";

interface Props {
    title: string;
    examples: { label: string; command: string }[];
}

const { examples, title } = Astro.props;
const command = skillSlashCommand(title);
---

<section class="mt-12">
    <h2
        class="font-mono text-xs text-neon-amber tracking-[0.3em] uppercase mb-5"
    >
        Example Prompts
    </h2>
    <div class="grid grid-cols-1 gap-4">
        {
            examples.map((example) => (
                <TerminalBlock label={example.label}>
                    <pre class="p-5 font-mono text-xs leading-relaxed text-cloud"><code><span class="text-neon-cyan select-none">&gt; </span>{command} {example.command}</code></pre>
                </TerminalBlock>
            ))
        }
    </div>
</section>
