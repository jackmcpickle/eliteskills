---
import TerminalBlock from '@/components/TerminalBlock.astro';

interface Props {
	slug: string;
}

const { slug } = Astro.props;
---

<section class="mt-16">
	<h2 class="font-mono text-xs text-neon-amber tracking-[0.3em] uppercase mb-5">Install</h2>
	<TerminalBlock label="Terminal">
		<pre class="p-5 font-mono text-sm text-cloud"><code><span class="text-neon-cyan">$</span> npx skills add jackmcpickle/eliteskills --skill {slug}</code></pre>
	</TerminalBlock>
</section>
