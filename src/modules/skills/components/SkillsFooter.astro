---

---

<footer class="relative py-24 px-6">
    <!-- Top border -->
    <div
        class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-neon-amber to-transparent"
    >
    </div>

    <div class="max-w-3xl mx-auto text-center">
        <h2
            class="reveal font-display text-3xl sm:text-4xl font-800 text-white tracking-tight mb-4"
        >
            Ready to Level Up?
        </h2>
        <p class="reveal reveal-delay-1 text-mist mb-8 max-w-lg mx-auto">
            Get the full skill pack and transform how your AI writes code.
        </p>
        <a
            href="/#pricing"
            class="reveal reveal-delay-2 group inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-neon-cyan text-void font-mono font-700 text-sm tracking-wide uppercase transition-all hover:shadow-[0_0_40px_var(--color-neon-cyan-dim)]"
        >
            <span>Get Elite Skills Now</span>
            <span class="transition-transform group-hover:translate-x-1"
                >&rarr;</span
            >
        </a>

        <div class="mt-20 pt-8 border-t border-border">
            <div class="mb-4 flex items-center justify-center gap-6">
                <a
                    href="/"
                    class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan"
                    >Home</a
                >
                <a
                    href="/skills"
                    class="font-mono text-xs uppercase tracking-[0.22em] text-neon-cyan"
                    >Skills</a
                >
                <a
                    href="/about"
                    class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan"
                    >About</a
                >
                <a
                    href="/contact"
                    class="font-mono text-xs uppercase tracking-[0.22em] text-ghost hover:text-neon-cyan"
                    >Contact</a
                >
            </div>
            <p class="font-mono text-xs text-ghost tracking-wider">
                &copy; {new Date().getFullYear()} Elite Skills &middot; Built by <span
                    class="text-mist">Jack McNicol</span
                >
            </p>
        </div>
    </div>
</footer>
