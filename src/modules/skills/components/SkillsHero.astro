<section class="relative pt-32 pb-20 px-6 overflow-hidden">
	<!-- Radial glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[800px] rounded-full bg-neon-cyan/5 blur-[160px] pointer-events-none"></div>

	<div class="relative z-10 max-w-4xl mx-auto text-center">
		<!-- Badge -->
		<div class="reveal inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full border border-neon-cyan-dim bg-neon-cyan-glow font-mono text-xs text-neon-cyan tracking-widest uppercase">
			<span class="size-1.5 rounded-full bg-neon-amber glow-pulse"></span>
			/elite skills
		</div>

		<h1 class="reveal reveal-delay-1 font-display text-5xl sm:text-6xl md:text-7xl font-900 tracking-tight leading-[0.95] mb-6">
			<span class="text-white">The </span>
			<span class="text-neon">Arsenal</span>
		</h1>

		<p class="reveal reveal-delay-2 max-w-2xl mx-auto text-lg sm:text-xl text-mist leading-relaxed">
