---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
	title="Contact — Elite Skills"
	description="Get in touch with Elite Skills. We usually reply within one business day."
	noindex
>
	<main id="main-content" class="min-h-screen px-6 py-20">
		<div class="max-w-3xl mx-auto rounded-2xl border border-border bg-surface p-8 sm:p-10">
			<p class="font-mono text-xs tracking-[0.28em] uppercase text-neon-cyan mb-4">Contact</p>
			<h1 class="font-display text-4xl font-800 text-white mb-3">Need help?</h1>
			<p class="text-mist mb-8">Send a message. We usually reply within one business day.</p>

			<form id="contact-form" class="space-y-5" novalidate>
				<!-- Honeypot — hidden from humans, bots auto-fill -->
				<div class="absolute -left-[9999px]" aria-hidden="true">
					<label for="website">Website</label>
					<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
				</div>

				<div>
					<label for="name" class="mb-2 block text-sm text-cloud">Name</label>
					<input id="name" name="name" type="text" required autocomplete="name" class="w-full rounded-lg border border-slate-mid bg-abyss px-4 py-3 text-white placeholder:text-ghost focus:border-neon-cyan focus:outline-none" />
				</div>

				<div>
					<label for="email" class="mb-2 block text-sm text-cloud">Email</label>
					<input id="email" name="email" type="email" required autocomplete="email" class="w-full rounded-lg border border-slate-mid bg-abyss px-4 py-3 text-white placeholder:text-ghost focus:border-neon-cyan focus:outline-none" />
				</div>

				<div>
					<label for="message" class="mb-2 block text-sm text-cloud">Message</label>
					<textarea id="message" name="message" required rows="6" class="w-full rounded-lg border border-slate-mid bg-abyss px-4 py-3 text-white placeholder:text-ghost focus:border-neon-cyan focus:outline-none"></textarea>
				</div>

				<button id="contact-submit" type="submit" class="w-full rounded-lg bg-neon-cyan py-4 text-sm font-mono font-700 uppercase tracking-wide text-void transition-all hover:shadow-[0_0_30px_var(--color-neon-cyan-dim)]">
					Send message
				</button>

				<p id="contact-status" class="min-h-5 text-sm text-mist" aria-live="polite"></p>
			</form>
		</div>
	</main>
</BaseLayout>

<script>
	const form = document.getElementById('contact-form');
	const submitButton = document.getElementById('contact-submit');
	const statusNode = document.getElementById('contact-status');

	if (form) {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!submitButton || !statusNode) return;

			statusNode.textContent = 'Sending...';
			submitButton.setAttribute('disabled', 'true');
			submitButton.classList.add('opacity-70');

			try {
				const formData = new FormData(form as HTMLFormElement);
				const response = await fetch('/api/contact', {
					method: 'POST',
					body: formData,
				});

				const result = await response.json();
				if (!response.ok) {
					statusNode.textContent = result.error || 'Message send failed.';
					statusNode.className = 'min-h-5 text-sm text-red-300';
					return;
				}

				statusNode.textContent = 'Message sent. Thanks.';
				statusNode.className = 'min-h-5 text-sm text-neon-green';
				(form as HTMLFormElement).reset();
			} catch (_error) {
				statusNode.textContent = 'Network issue. Try again.';
				statusNode.className = 'min-h-5 text-sm text-red-300';
			} finally {
				submitButton.removeAttribute('disabled');
				submitButton.classList.remove('opacity-70');
			}
		});
	}
</script>
