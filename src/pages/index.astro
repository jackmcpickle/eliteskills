---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
	HeroBanner,
	SkillsGrid,
	ReviewsMarquee,
	BenefitsSection,
	PricingTables,
	FooterCta,
} from '@/modules/home';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');
const pricing = await getCollection('pricing');

const SITE_URL = 'https://eliteskills.dev';

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Elite Skills',
	url: SITE_URL,
	description: 'Elite AI Skills for programmers and vibe coders. 20 years of engineering distilled into precision-crafted AI instruction sets.',
};

const productJsonLd = pricing.map((tier) => ({
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: tier.data.title,
	description: tier.data.description,
	offers: {
		'@type': 'Offer',
		price: tier.data.price,
		priceCurrency: 'USD',
		availability: 'https://schema.org/InStock',
		url: `${SITE_URL}/checkout/${tier.id}`,
	},
}));

const reviewJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: 'Elite AI Skills',
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: (reviews.reduce((sum, r) => sum + r.data.rating, 0) / reviews.length).toFixed(1),
		reviewCount: reviews.length,
		bestRating: 5,
	},
	review: reviews.map((r) => ({
		'@type': 'Review',
		author: { '@type': 'Person', name: r.data.name },
		reviewRating: { '@type': 'Rating', ratingValue: r.data.rating, bestRating: 5 },
	})),
};
---

<BaseLayout
	title="Elite Skills — AI Skills for Builders"
	description="Elite AI Skills for programmers and vibe coders. 20 years of engineering distilled into precision-crafted AI instruction sets."
	jsonLd={[websiteJsonLd, ...productJsonLd, reviewJsonLd]}
>
	<HeroBanner />
	<SkillsGrid />
	<ReviewsMarquee />
	<BenefitsSection />
	<PricingTables />
	<FooterCta />
</BaseLayout>
