---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import {
	HeroBanner,
	CompatibleTools,
	SkillsGrid,
	MetricsBar,
	ReviewsMarquee,
	BenefitsSection,
	DifferentiatorSection,
	AiBotSection,
	FooterCta,
	WhatAreSkills,
} from '@/modules/home';
import { getCollection } from 'astro:content';

const reviews = await getCollection('reviews');

const SITE_URL = 'https://eliteskills.ai';

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Elite Skills',
	url: SITE_URL,
	description: 'Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets.',
};



const reviewJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: 'Elite AI Skills',
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: (reviews.reduce((sum, r) => sum + r.data.rating, 0) / reviews.length).toFixed(1),
		reviewCount: reviews.length,
		bestRating: 5,
	},
	review: reviews.map((r) => ({
		'@type': 'Review',
		author: { '@type': 'Person', name: r.data.name },
		reviewRating: { '@type': 'Rating', ratingValue: r.data.rating, bestRating: 5 },
	})),
};
---

<BaseLayout
	title="Elite Skills — AI Skills for Builders"
	description="Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets."
	jsonLd={[websiteJsonLd, reviewJsonLd]}
>
	<HeroBanner />
	<WhatAreSkills />
	<SkillsGrid />
	<MetricsBar />
	<ReviewsMarquee />
	<BenefitsSection />
	<DifferentiatorSection />
	<CompatibleTools />

	<AiBotSection />
	<FooterCta />

	<script>
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						if (entry.target.classList.contains('snake-grid')) {
							const cells = entry.target.querySelectorAll('.snake-cell');
							const cols = window.matchMedia('(min-width: 1024px)').matches ? 3
								: window.matchMedia('(min-width: 640px)').matches ? 2 : 1;
							requestAnimationFrame(() => {
								cells.forEach((cell, i) => {
									const row = Math.floor(i / cols);
									const col = i % cols;
									const order = row * cols + (row % 2 === 0 ? col : cols - 1 - col);
									(cell as HTMLElement).style.setProperty('--snake-order', String(order));
								});
							});
						}
						entry.target.classList.add('in-view');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
		);
		document.querySelectorAll('.scroll-sheen, .scroll-border-trace, .snake-grid').forEach((el) => {
			observer.observe(el);
		});
	</script>
</BaseLayout>
