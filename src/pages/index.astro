---
import '@/styles/global.css';
import HeroBanner from '@/modules/home/components/HeroBanner.astro';
import SkillsGrid from '@/modules/home/components/SkillsGrid.astro';
import ReviewsMarquee from '@/modules/home/components/ReviewsMarquee.astro';
import BenefitsSection from '@/modules/home/components/BenefitsSection.astro';
import PricingTables from '@/modules/home/components/PricingTables.astro';
import FooterCta from '@/modules/home/components/FooterCta.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Elite AI Skills for programmers and vibe coders. 20 years of engineering distilled into precision-crafted AI instruction sets." />
		<meta name="generator" content={Astro.generator} />
		<title>Elite Skills — AI Skills for Builders</title>
	</head>
	<body>
		<HeroBanner />
		<SkillsGrid />
		<ReviewsMarquee />
		<BenefitsSection />
		<PricingTables />
		<FooterCta />
	</body>
</html>
