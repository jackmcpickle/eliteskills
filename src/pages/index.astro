---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import {
	HeroBanner,
	CompatibleTools,
	SkillsGrid,
	MetricsBar,
	ReviewsMarquee,
	BenefitsSection,
	DifferentiatorSection,
	PricingTables,
	AiBotSection,
	FooterCta,
	WhatAreSkills,
} from '@/modules/home';
import { getCollection } from 'astro:content';
import { createDb } from '@/libs/db/client';
import { listProducts, getProductPrice } from '@/libs/db/repo';
import { resolveContinent, resolveCountryCode, resolveLocale } from '@/libs/geo';

const reviews = await getCollection('reviews');

const d1 = Astro.locals.runtime.env.DB;
const db = createDb(d1);
const dbProducts = await listProducts(db);

const cf = Astro.locals.runtime.cf as { continent?: string; country?: string } | undefined;
const continent = resolveContinent(cf, Astro.request.headers.get('cf-ipcontinent'));
const countryCode = resolveCountryCode(cf, Astro.request.headers.get('cf-ipcountry'));
const locale = resolveLocale(countryCode);

// Build product map with geo price + currency
const priceRows = await Promise.all(
	dbProducts.map((p) => getProductPrice(db, p.id, continent, countryCode)),
);

const productMap = new Map<number, { id: number; code: string; name: string; price: number; currency: string; lifetime: number; skillSlug: string | null }>();
for (let i = 0; i < dbProducts.length; i += 1) {
	const p = dbProducts[i];
	if (!p) continue;
	const priceRow = priceRows[i];
	productMap.set(p.id, {
		id: p.id,
		code: p.code,
		name: p.name,
		price: priceRow?.price ?? 0,
		currency: priceRow?.currency ?? 'usd',
		lifetime: p.lifetime,
		skillSlug: p.skillSlug,
	});
}

const bundleProducts = [...productMap.values()].filter((p) => !p.skillSlug);
const skillProducts = [...productMap.values()].filter((p) => p.skillSlug);

const SITE_URL = 'https://eliteskills.ai';

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Elite Skills',
	url: SITE_URL,
	description: 'Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets.',
};

const productJsonLd = bundleProducts.map((p) => ({
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: p.name,
	offers: {
		'@type': 'Offer',
		price: p.price,
		priceCurrency: p.currency.toUpperCase(),
		availability: 'https://schema.org/InStock',
		url: `${SITE_URL}/checkout/${p.id}`,
	},
}));

const reviewJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: 'Elite AI Skills',
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: (reviews.reduce((sum, r) => sum + r.data.rating, 0) / reviews.length).toFixed(1),
		reviewCount: reviews.length,
		bestRating: 5,
	},
	review: reviews.map((r) => ({
		'@type': 'Review',
		author: { '@type': 'Person', name: r.data.name },
		reviewRating: { '@type': 'Rating', ratingValue: r.data.rating, bestRating: 5 },
	})),
};
---

<BaseLayout
	title="Elite Skills — AI Skills for Builders"
	description="Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets."
	jsonLd={[websiteJsonLd, ...productJsonLd, reviewJsonLd]}
>
	<HeroBanner />
	<WhatAreSkills />
	<SkillsGrid skillProducts={skillProducts} locale={locale} />
	<MetricsBar />
	<ReviewsMarquee />
	<BenefitsSection />
	<DifferentiatorSection />
	<CompatibleTools />
	<PricingTables bundleProducts={bundleProducts} skillProducts={skillProducts} locale={locale} />
	<AiBotSection />
	<FooterCta />

	<script>
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						if (entry.target.classList.contains('snake-grid')) {
							const cells = entry.target.querySelectorAll('.snake-cell');
							const cols = getComputedStyle(entry.target).gridTemplateColumns.split(' ').length;
							cells.forEach((cell, i) => {
								const row = Math.floor(i / cols);
								const col = i % cols;
								const order = row * cols + (row % 2 === 0 ? col : cols - 1 - col);
								(cell as HTMLElement).style.setProperty('--snake-order', String(order));
							});
						}
						entry.target.classList.add('in-view');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
		);
		document.querySelectorAll('.scroll-sheen, .scroll-border-trace, .snake-grid').forEach((el) => {
			observer.observe(el);
		});
	</script>
</BaseLayout>
