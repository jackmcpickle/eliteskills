---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import {
	HeroBanner,
	CompatibleTools,
	SkillsGrid,
	MetricsBar,
	ReviewsMarquee,
	BenefitsSection,
	DifferentiatorSection,
	PricingTables,
	AiBotSection,
	FooterCta,
} from '@/modules/home';
import { getCollection } from 'astro:content';
import { createDb } from '@/libs/db/client';
import { listProducts, getProductPrice } from '@/libs/db/repo';
import { resolveContinent } from '@/libs/geo';

const reviews = await getCollection('reviews');

const d1 = Astro.locals.runtime.env.DB;
const db = createDb(d1);
const dbProducts = await listProducts(db);

const cf = Astro.locals.runtime.cf as { continent?: string } | undefined;
const continent = resolveContinent(cf, Astro.request.headers.get('cf-ipcontinent'));

// Build product map with geo price
const productMap = new Map<number, { id: number; code: string; name: string; price: number; lifetime: number; skillSlug: string | null }>();
for (const p of dbProducts) {
	const priceRow = await getProductPrice(db, p.id, continent);
	productMap.set(p.id, {
		id: p.id,
		code: p.code,
		name: p.name,
		price: priceRow?.price ?? 0,
		lifetime: p.lifetime,
		skillSlug: p.skillSlug,
	});
}

const bundleProducts = [...productMap.values()].filter((p) => !p.skillSlug);
const skillProducts = [...productMap.values()].filter((p) => p.skillSlug);

const SITE_URL = 'https://eliteskills.ai';

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Elite Skills',
	url: SITE_URL,
	description: 'Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets.',
};

const productJsonLd = bundleProducts.map((p) => ({
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: p.name,
	offers: {
		'@type': 'Offer',
		price: p.price,
		priceCurrency: 'USD',
		availability: 'https://schema.org/InStock',
		url: `${SITE_URL}/checkout/${p.id}`,
	},
}));

const reviewJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: 'Elite AI Skills',
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: (reviews.reduce((sum, r) => sum + r.data.rating, 0) / reviews.length).toFixed(1),
		reviewCount: reviews.length,
		bestRating: 5,
	},
	review: reviews.map((r) => ({
		'@type': 'Review',
		author: { '@type': 'Person', name: r.data.name },
		reviewRating: { '@type': 'Rating', ratingValue: r.data.rating, bestRating: 5 },
	})),
};
---

<BaseLayout
	title="Elite Skills — AI Skills for Builders"
	description="Elite AI Skills for vibe coders, founders, and builders. 20 years of engineering distilled into precision-crafted AI instruction sets."
	jsonLd={[websiteJsonLd, ...productJsonLd, reviewJsonLd]}
>
	<HeroBanner />
	<SkillsGrid skillProducts={skillProducts} />
	<MetricsBar />
	<ReviewsMarquee />
	<BenefitsSection />
	<DifferentiatorSection />
	<CompatibleTools />
	<PricingTables bundleProducts={bundleProducts} skillProducts={skillProducts} />
	<AiBotSection />
	<FooterCta />
</BaseLayout>
