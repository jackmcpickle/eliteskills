---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';

const error = Astro.url.searchParams.get('error');
const errorMsg = error === 'expired' ? 'Link expired. Request a new one.' : error === 'invalid' ? 'Invalid link. Try again.' : '';
---

<BaseLayout
	title="Login — Elite Skills"
	description="Access your Elite Skills account via magic link."
	noindex
>
	<main id="main-content" class="min-h-screen px-6 py-20">
		<div class="max-w-md mx-auto rounded-2xl border border-border bg-surface p-8 sm:p-10">
			<p class="font-mono text-xs tracking-[0.28em] uppercase text-neon-cyan mb-4">Login</p>
			<h1 class="font-display text-4xl font-800 text-white mb-3">Access your account</h1>
			<p class="text-mist mb-8">Enter your email and we'll send a login link.</p>

			{errorMsg && (
				<p class="text-sm text-red-300 mb-4">{errorMsg}</p>
			)}

			<form id="login-form" class="space-y-5" novalidate>
				<!-- Honeypot -->
				<div class="absolute -left-[9999px]" aria-hidden="true">
					<label for="website">Website</label>
					<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
				</div>

				<div>
					<label for="email" class="mb-2 block text-sm text-cloud">Email</label>
					<input id="email" name="email" type="email" required autocomplete="email" class="w-full rounded-lg border border-slate-mid bg-abyss px-4 py-3 text-white placeholder:text-ghost focus:border-neon-cyan focus:outline-none" />
				</div>

				<button id="login-submit" type="submit" class="w-full rounded-lg bg-neon-cyan py-4 text-sm font-mono font-700 uppercase tracking-wide text-void transition-all hover:shadow-[0_0_30px_var(--color-neon-cyan-dim)]">
					Send login link
				</button>

				<p id="login-status" class="min-h-5 text-sm text-mist" aria-live="polite"></p>
			</form>
		</div>
	</main>
</BaseLayout>

<script>
	import { initFormSubmit } from '../scripts/form-submit';
	initFormSubmit({
		formId: 'login-form',
		submitId: 'login-submit',
		statusId: 'login-status',
		action: '/api/send-login-link',
		successMessage: 'Check your email for a login link.',
	});
</script>
