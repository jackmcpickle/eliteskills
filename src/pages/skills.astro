---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SkillsHero, SkillsList, SkillsFooter } from '@/modules/skills';
import { DEFAULT_SKILL_PRODUCTS, DEFAULT_LOCALE } from '@/constants/default-prices';

const skills = (await getCollection('skills')).sort((a, b) => a.data.order - b.data.order);

const skillProducts = DEFAULT_SKILL_PRODUCTS;
const locale = DEFAULT_LOCALE;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Elite AI Skills',
	description: 'Precision-engineered AI instruction sets for builders.',
	itemListElement: skills.map((skill, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: skill.data.title,
		description: skill.data.description,
	})),
};
---

<BaseLayout
	title="Skills — Elite Skills"
	description="Six precision-engineered AI instruction sets covering react, python, style, architecture review, app bootstrap, and feature enhancement."
	jsonLd={jsonLd}
>
	<SkillsHero />
	<SkillsList skillProducts={skillProducts} locale={locale} />
	<SkillsFooter />
</BaseLayout>
