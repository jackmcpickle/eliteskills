---
export const prerender = true;

import { getCollection } from "astro:content";
import {
    Check,
    ClipboardCheck,
    Database,
    FlaskConical,
    GitBranch,
    Layers,
    Palette,
    Rocket,
    ShieldCheck,
    Sparkles,
} from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { skillSlug as toSkillSlug } from "@/utils/skill-command";
import {
    SkillInstall,
    SkillStructure,
    SkillExamples,
    SkillBestPractices,
    SkillUsageLinks,
} from "@/modules/skills";

export async function getStaticPaths() {
    const skills = await getCollection("skills");
    return skills.map((s) => ({ params: { slug: s.id.replace(/\.md$/, "") } }));
}

const { slug } = Astro.params;
const skills = await getCollection("skills");
const skill = skills.find((s) => s.id.replace(/\.md$/, "") === slug);

if (!skill) return Astro.redirect("/skills");

const {
    title,
    description,
    icon,
    order,
    highlights,
    released,
    isNew,
    examples,
    bestPractices,
    structure,
} = skill.data;


const iconMap = { ClipboardCheck, Database, FlaskConical, GitBranch, Layers, Palette, Rocket, ShieldCheck, Sparkles };
const Icon = iconMap[icon as keyof typeof iconMap] ?? Sparkles;
---

<BaseLayout title={`${title} — Elite Skills`} description={description} ogImage={`https://eliteskills.ai/og/${slug}.png`}>
    <main id="main-content" class="relative py-16 sm:py-24 lg:py-32 px-6">
        <!-- Ambient glow -->
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 size-125 rounded-full bg-neon-cyan/5 blur-[140px] pointer-events-none"
        >
        </div>

        <div class="relative max-w-3xl mx-auto">
            <!-- Header -->
            <div class="flex items-center gap-4 mb-8">
                <div
                    class="flex items-center justify-center size-16 rounded-xl bg-neon-cyan-glow border border-neon-cyan-dim text-neon-cyan"
                    transition:name={`skill-icon-${slug}`}
                >
                    <Icon class="size-7" aria-hidden="true" />
                </div>
                <div>
                    <div class="flex items-center gap-3">
                        <h1
                            class="font-display text-4xl sm:text-5xl font-800 tracking-tight"
                            transition:name={`skill-title-${slug}`}
                        >
                            <span class="text-white">/elite-</span><span class="text-neon-cyan">{toSkillSlug(title)}</span>
                        </h1>
                        {
                            !released && (
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full border border-neon-amber/40 bg-neon-amber/10 font-mono text-xs text-neon-amber tracking-wider uppercase">
                                    Coming Soon
                                </span>
                            )
                        }
                        {
                            isNew && (
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full border border-neon-cyan/40 bg-neon-cyan/10 font-mono text-xs text-neon-cyan tracking-wider uppercase animate-pulse">
                                    New
                                </span>
                            )
                        }
                    </div>
                    <span
                        class="font-mono text-[10px] text-ghost tracking-[0.3em] uppercase"
                        >Skill {String(order).padStart(2, "0")}</span
                    >
                </div>
            </div>

            <p class="text-mist text-lg leading-relaxed mb-12 max-w-2xl">
                {description}
            </p>

            <!-- Highlights -->
            {
                highlights.length > 0 && (
                    <div class="mb-12">
                        <h2 class="font-mono text-xs text-neon-amber tracking-[0.3em] uppercase mb-5">
                            What It Covers
                        </h2>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {highlights.map((highlight) => (
                                <li class="flex items-start gap-3 text-sm">
                                    <div class="flex items-center justify-center size-6 rounded bg-neon-cyan-glow text-neon-cyan shrink-0 mt-0.5">
                                        <Check
                                            class="size-3.5"
                                            aria-hidden="true"
                                        />
                                    </div>
                                    <span class="text-cloud">{highlight}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )
            }

            <!-- Install command -->
            {
                released ? (
                    <div class="rounded-lg border border-border bg-surface/50 p-6">
                        <h3 class="font-mono text-xs text-neon-cyan tracking-[0.3em] uppercase mb-3">Install This Skill</h3>
                        <div class="flex items-center gap-4 mb-3">
                            <div class="flex-1 px-4 py-3 rounded-lg bg-void/50 border border-border font-mono text-sm text-neon-cyan">
                                <span class="select-all">npx skills add jackmcpickle/eliteskills --skill elite-{toSkillSlug(title)}</span>
                            </div>
                        </div>
                        <p class="font-mono text-xs text-ghost">
                            Or install all skills: <span class="text-mist select-all">npx skills add jackmcpickle/eliteskills</span>
                        </p>
                    </div>
                ) : (
                    <span class="inline-flex items-center gap-2 px-8 py-4 rounded-lg border border-ghost/30 text-ghost font-mono font-700 text-sm tracking-wide uppercase cursor-default">
                        Coming Soon
                    </span>
                )
            }

            {
                released && (
                    <>
                        <SkillInstall slug={slug!} />
                        {structure.length > 0 && (
                            <SkillStructure
                                slug={slug!}
                                structure={structure}
                            />
                        )}
                        {examples.length > 0 && (
                            <SkillExamples title={title} examples={examples} />
                        )}
                        {bestPractices.length > 0 && (
                            <SkillBestPractices bestPractices={bestPractices} />
                        )}
                        <SkillUsageLinks />
                    </>
                )
            }
        </div>
    </main>
</BaseLayout>
